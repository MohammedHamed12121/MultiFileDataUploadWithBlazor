@page "/"


<InputFile OnChange="OnFileChanged" multiple></InputFile>
<pre>@status</pre>

<Grid TItem="Employee" Class="table table-hover border-top" Data="@employees">
	<GridColumns>
		<GridColumn TItem="Employee" HeaderText="Id" PropertyName="Id">
			@context.Id
		</GridColumn>
		<GridColumn TItem="Employee" HeaderText="Employee Name" PropertyName="Name">
			@context.Name
		</GridColumn>
		<GridColumn TItem="Employee" HeaderText="Designation" PropertyName="Designation">
			@context.Designation
		</GridColumn>
		<GridColumn TItem="Employee" HeaderText="DOJ" PropertyName="DOJ">
			@context.DOJ
		</GridColumn>
		<GridColumn TItem="Employee" HeaderText="Active" PropertyName="IsActive">
			@context.IsActive
		</GridColumn>
	</GridColumns>
</Grid>

@code {
	string? status;

	async void OnFileChanged(InputFileChangeEventArgs e)
	{
		try
		{
			ImportFileProcessor processor = null;

			var buffer = new byte[4096];
			foreach (var file in e.GetMultipleFiles(e.FileCount))
			{
				status += "\nReading file: " + file.Name;

				// Get the file type
				string fileType = file.ContentType;
				switch (fileType.ToLower())
				{
					case "text/csv":
						processor = new ImportFileProcessor(new CsvFileImporter());
						break;
					case "application/json":
						processor = new ImportFileProcessor(new JsonFileImporter());
						break;
					default:
						status += "\nUnsupported file type: " + fileType + " for file: " + file.Name;
						break;
				}

				if (processor != null)
				{
					List<Employee> newEmployees = processor.ProcessImport();
					EmployeeService.AddEmployee(newEmployees);
					status += "\nSuccessfully processed file: " + file.Name;
					RefreshEmployees();
				}
			}

		}
		catch (Exception ex)
		{
			status += "\nError: " + ex.Message;
			_ = InvokeAsync(StateHasChanged);
		}
	}



	private IReadOnlyList<Employee> employees;

	protected override void OnInitialized()
	{
		employees = EmployeeService.GetEmployees();
	}

	private void RefreshEmployees()
	{
		employees = EmployeeService.GetEmployees();
		_ = InvokeAsync(StateHasChanged);
	}
}